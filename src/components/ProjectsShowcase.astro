---
import projectsFile from '../data/projects.json';
import { withBase } from '../lib/assetPath';
import { icons } from '../lib/icons';
const projectsData = projectsFile.items;
---

<section id="projects" class="projects-section">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 reveal visible">
      <p class="text-sm font-semibold tracking-widest text-highlight uppercase mb-3">My work</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold section-title">Projects</h2>
    </div>

    <div class="projects-list">
      {
        projectsData.map((project, index) => {
          const hasImages = Boolean(project.backgroundImage && (project as any).images?.length);
          const ctaLabel = project.link.includes('github.com') ? 'View on GitHub'
            : project.link.includes('gitlab') ? 'View on GitLab'
            : project.link ? 'View Project'
            : null;

          return (
            <article class={`project-feature reveal visible ${hasImages ? '' : 'project-feature--compact'}`} data-index={index}>
              <div class="project-art">
                {hasImages ? (
                  <>
                    <img
                      class="project-main-image"
                      src={withBase(project.backgroundImage!)}
                      alt={`${project.title} screenshot`}
                      loading="lazy"
                      width="900"
                      height="560"
                    />
                    <div class="project-art-overlay" />
                    <div class="project-shots">
                      {(project as any).images?.slice(0, 3).map((image: string, i: number) => (
                        <button
                          type="button"
                          class={`project-shot-button ${image === project.backgroundImage ? 'active' : ''}`}
                          data-gallery={String(index)}
                          data-image={withBase(image)}
                          aria-label={`Show ${project.title} screenshot ${i + 1}`}
                        >
                          <img src={withBase(image)} alt="" loading="lazy" width="160" height="90" />
                        </button>
                      ))}
                    </div>
                  </>
                ) : (
                  <div class="project-code-art" aria-hidden="true">
                    <div class="project-code-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" set:html={icons[project.icon ?? ''] ?? icons['code-bracket-square']} />
                    </div>
                    {project.tags.slice(0, 3).map((tag) => (
                      <span>{tag}</span>
                    ))}
                  </div>
                )}
              </div>

              <div class="project-copy">
                {project.company && <p class="project-eyebrow">{project.company}</p>}
                <h3>{project.title}</h3>
                <p class="project-description">{project.description}</p>

                <div class="project-tags">
                  {project.tags.map((tag) => (
                    <span>{tag}</span>
                  ))}
                </div>

                {ctaLabel && (
                  <a href={project.link} target="_blank" rel="noopener" class="project-link">
                    {ctaLabel}
                    <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
                      <path
                        d="M3 10h14M10 3l7 7-7 7"
                        stroke="currentColor"
                        stroke-width="1.75"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </a>
                )}
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<script>
  const shotButtons = document.querySelectorAll<HTMLButtonElement>('.project-shot-button');

  shotButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const nextImage = button.dataset.image;
      const projectCard = button.closest('.project-feature');
      const mainImage = projectCard?.querySelector<HTMLImageElement>('.project-main-image');
      if (!mainImage || !nextImage || !projectCard) return;

      mainImage.src = nextImage;
      projectCard.querySelectorAll('.project-shot-button').forEach((item) => item.classList.remove('active'));
      button.classList.add('active');
    });
  });
</script>

<style>
  .projects-section {
    padding: 6rem 0;
    background: rgba(15, 23, 42, 0.3);
    scroll-margin-top: 80px;
  }

  .projects-list {
    display: grid;
    gap: 1.4rem;
    max-width: 980px;
    margin: 0 auto;
  }

  .project-feature {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    min-height: 26rem;
    margin: 0;
    overflow: hidden;
    border: 1px solid rgba(99, 102, 241, 0.22);
    border-radius: 1.25rem;
    background:
      radial-gradient(circle at 15% 15%, rgba(16, 185, 129, 0.16), transparent 34%),
      linear-gradient(135deg, rgba(15, 23, 42, 0.92), rgba(2, 6, 23, 0.82));
    box-shadow: 0 28px 80px rgba(2, 6, 23, 0.38);
  }

  .project-feature--compact {
    min-height: 22rem;
  }

  @media (min-width: 768px) {
    .project-feature {
      grid-template-columns: 1.05fr 0.95fr;
    }
  }

  .project-art {
    position: relative;
    min-height: 17rem;
    overflow: hidden;
  }

  .project-code-art {
    position: relative;
    display: grid;
    place-content: center;
    gap: 0.75rem;
    min-height: 17rem;
    height: 100%;
    padding: 2rem;
    background:
      radial-gradient(circle at 32% 22%, rgba(56, 189, 248, 0.18), transparent 32%),
      radial-gradient(circle at 70% 72%, rgba(52, 211, 153, 0.14), transparent 34%),
      linear-gradient(135deg, rgba(15, 23, 42, 0.94), rgba(2, 6, 23, 0.78));
    color: #93c5fd;
  }

  .project-code-icon {
    display: grid;
    place-items: center;
    width: 5rem;
    height: 5rem;
    margin: 0 auto 0.5rem;
    border: 1px solid rgba(56, 189, 248, 0.24);
    border-radius: 1.1rem;
    background: rgba(15, 23, 42, 0.72);
  }

  .project-code-icon svg {
    width: 2.5rem;
    height: 2.5rem;
  }

  .project-code-art span {
    justify-self: center;
    border: 1px solid rgba(99, 102, 241, 0.22);
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.08);
    color: #c4b5fd;
    padding: 0.35rem 0.8rem;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .project-art > img {
    width: 100%;
    height: 100%;
    min-height: 17rem;
    object-fit: cover;
    display: block;
    filter: saturate(1.15) brightness(0.72);
    transform: scale(1.04);
    transition:
      transform 0.5s ease,
      filter 0.5s ease;
  }

  .project-feature:hover .project-art > img {
    transform: scale(1.09);
    filter: saturate(1.3) brightness(0.82);
  }

  .project-art-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(2, 6, 23, 0.08), rgba(2, 6, 23, 0.72));
  }

  .project-shots {
    position: absolute;
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
    z-index: 2;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.55rem;
  }

  .project-shot-button {
    display: block;
    width: 100%;
    padding: 0;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 0.45rem;
    background: rgba(15, 23, 42, 0.78);
    cursor: pointer;
    transition:
      transform 0.22s ease,
      border-color 0.22s ease,
      box-shadow 0.22s ease;
  }

  .project-shot-button:hover,
  .project-shot-button.active {
    transform: translateY(-2px);
    border-color: rgba(52, 211, 153, 0.78);
    box-shadow: 0 10px 24px rgba(2, 6, 23, 0.34);
  }

  .project-shot-button:focus-visible {
    outline: 2px solid #34d399;
    outline-offset: 3px;
  }

  .project-shot-button img {
    width: 100%;
    aspect-ratio: 16 / 9;
    min-height: 0;
    display: block;
    object-fit: cover;
    filter: saturate(1.1) brightness(0.9);
    transform: none;
  }

  .project-feature:hover .project-shot-button img {
    transform: none;
    filter: saturate(1.2) brightness(1);
  }

  .project-copy {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem;
  }

  @media (min-width: 768px) {
    .project-copy {
      padding: 2.75rem;
    }
  }

  .project-eyebrow {
    margin: 0 0 0.7rem;
    color: #34d399;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .project-copy h3 {
    margin: 0;
    color: var(--text);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: 0;
  }

  .project-description {
    max-width: 34rem;
    margin: 1.2rem 0 0;
    color: var(--text-muted);
    font-size: 0.98rem;
    line-height: 1.75;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.4rem;
  }

  .project-tags span {
    border: 1px solid rgba(52, 211, 153, 0.18);
    border-radius: 999px;
    background: rgba(16, 185, 129, 0.08);
    color: #a7f3d0;
    padding: 0.35rem 0.75rem;
    font-size: 0.74rem;
    font-weight: 700;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    gap: 0.6rem;
    margin-top: 1.75rem;
    color: #020617;
    background: #34d399;
    border-radius: 999px;
    padding: 0.78rem 1.15rem;
    font-size: 0.9rem;
    font-weight: 900;
    text-decoration: none;
    transition:
      transform 0.22s ease,
      filter 0.22s ease,
      gap 0.22s ease;
  }

  .project-link:hover {
    gap: 0.85rem;
    filter: brightness(1.08);
    transform: translateY(-2px);
  }

  .project-link svg {
    width: 1rem;
    height: 1rem;
  }

  :global([data-theme='light']) .projects-section {
    background: rgba(241, 245, 249, 0.5);
  }
  :global([data-theme='light']) .project-feature {
    background:
      radial-gradient(circle at 15% 15%, rgba(16, 185, 129, 0.08), transparent 34%),
      var(--bg-card);
    border-color: rgba(99, 102, 241, 0.16);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.08);
  }
  :global([data-theme='light']) .project-code-art {
    background:
      radial-gradient(circle at 32% 22%, rgba(99, 102, 241, 0.1), transparent 32%),
      radial-gradient(circle at 70% 72%, rgba(16, 185, 129, 0.08), transparent 34%),
      linear-gradient(135deg, rgba(241, 245, 249, 0.96), rgba(226, 232, 240, 0.88));
    color: var(--accent);
  }
  :global([data-theme='light']) .project-code-icon {
    background: rgba(241, 245, 249, 0.9);
    border-color: rgba(99, 102, 241, 0.2);
  }
  :global([data-theme='light']) .project-code-art span {
    color: var(--accent);
    background: rgba(99, 102, 241, 0.08);
    border-color: rgba(99, 102, 241, 0.2);
  }
  :global([data-theme='light']) .project-eyebrow {
    color: #059669;
  }
  :global([data-theme='light']) .project-tags span {
    border-color: rgba(16, 185, 129, 0.3);
    background: rgba(16, 185, 129, 0.08);
    color: #065f46;
  }
  :global([data-theme='light']) .project-art-overlay {
    background: linear-gradient(90deg, rgba(248, 250, 252, 0.04), rgba(248, 250, 252, 0.55));
  }
  :global([data-theme='light']) .project-shot-button {
    background: rgba(241, 245, 249, 0.85);
    border-color: rgba(148, 163, 184, 0.3);
  }
  :global([data-theme='light']) .project-shot-button:hover,
  :global([data-theme='light']) .project-shot-button.active {
    border-color: rgba(16, 185, 129, 0.6);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.1);
  }
</style>
