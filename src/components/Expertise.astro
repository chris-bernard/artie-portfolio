---
import expertiseFile from '../data/expertise.json';
import { icons } from '../lib/icons';

type ExpertiseItem = {
  key: string;
  icon?: string;
  iconifyIcon?: string;
  title: string;
  description: string;
};

const expertiseData = expertiseFile.items as ExpertiseItem[];
---

<section id="expertise" class="py-20" style="scroll-margin-top: 80px;">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14 reveal">
      <p class="text-sm font-semibold tracking-widest text-highlight uppercase mb-3">What I do</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold section-title">Expertise</h2>
    </div>

    <div class="expertise-grid max-w-6xl mx-auto">
      {
        expertiseData.map((item, i) => (
          <article class="expertise-card reveal" style={`transition-delay:${i * 0.08}s`}>
            <div class="expertise-icon-wrap" aria-hidden="true">
              {item.iconifyIcon ? (
                <iconify-icon icon={item.iconifyIcon} width="32" height="32" />
              ) : (
                <svg class="expertise-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" set:html={icons[item.icon ?? ''] ?? icons.sparkles} />
              )}
            </div>
            <div class="expertise-copy">

              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('#expertise .reveal').forEach((el) => {
    const io = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          el.classList.add('visible');
          io.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    io.observe(el);
  });
</script>

<style>
  .expertise-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2rem;
  }

  @media (min-width: 768px) {
    .expertise-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .expertise-card {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(99, 102, 241, 0.18);
    border-radius: 1rem;
    background:
      linear-gradient(180deg, rgba(15, 23, 42, 0.84), rgba(2, 6, 23, 0.68)),
      var(--bg-card);
    transition:
      transform 0.32s ease,
      border-color 0.32s ease,
      box-shadow 0.32s ease;
  }

  .expertise-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 10%, rgba(56, 189, 248, 0.16), transparent 34%),
      radial-gradient(circle at 88% 18%, rgba(52, 211, 153, 0.12), transparent 30%);
    opacity: 0;
    transition: opacity 0.32s ease;
    pointer-events: none;
  }

  .expertise-card:hover {
    transform: translateY(-5px);
    border-color: rgba(99, 102, 241, 0.48);
    box-shadow: 0 20px 54px rgba(2, 6, 23, 0.34);
  }

  .expertise-card:hover::before {
    opacity: 1;
  }

  .expertise-icon-wrap {
    position: relative;
    z-index: 1;
    display: grid;
    place-items: center;
    width: 4rem;
    height: 4rem;
    margin: 1.25rem 1.25rem 0;
    border: 1px solid rgba(56, 189, 248, 0.2);
    border-radius: 1rem;
    background:
      linear-gradient(135deg, rgba(56, 189, 248, 0.14), rgba(52, 211, 153, 0.08)),
      rgba(15, 23, 42, 0.78);
    color: #7dd3fc;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
    transition:
      transform 0.32s ease,
      color 0.32s ease,
      border-color 0.32s ease;
  }

  .expertise-card:hover .expertise-icon-wrap {
    transform: translateY(-3px) rotate(-4deg);
    border-color: rgba(52, 211, 153, 0.38);
    color: #a7f3d0;
  }

  .expertise-icon {
    width: 2rem;
    height: 2rem;
  }

  .expertise-copy {
    position: relative;
    z-index: 1;
    padding: 1.25rem;
  }

  .expertise-index {
    display: inline-flex;
    margin-bottom: 0.65rem;
    color: #38bdf8;
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.18em;
  }

  .expertise-copy h3 {
    margin: 0;
    color: var(--text);
    font-size: 1.08rem;
    font-weight: 800;
    line-height: 1.25;
  }

  .expertise-copy p {
    margin: 0.65rem 0 0;
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.65;
  }

  :global([data-theme='light']) .expertise-card {
    background: var(--bg-card);
    border-color: rgba(99, 102, 241, 0.14);
  }
  :global([data-theme='light']) .expertise-card:hover {
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.1);
  }
  :global([data-theme='light']) .expertise-icon-wrap {
    background:
      linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(52, 211, 153, 0.06)),
      rgba(241, 245, 249, 0.9);
    border-color: rgba(99, 102, 241, 0.2);
    color: var(--accent);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.6);
  }
  :global([data-theme='light']) .expertise-card:hover .expertise-icon-wrap {
    color: #059669;
    border-color: rgba(16, 185, 129, 0.38);
  }
  :global([data-theme='light']) .expertise-index {
    color: var(--accent);
  }
</style>
