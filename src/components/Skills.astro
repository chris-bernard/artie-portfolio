---
import skillsData from '../data/skills.json';
import { withBase } from '../lib/assetPath';

const { section, categories } = skillsData;
---

<section id="skills" class="py-24" style="scroll-margin-top: 80px;">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-16 reveal">
      <p class="text-sm font-semibold tracking-widest text-highlight uppercase mb-3">{section.eyebrow}</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold section-title">{section.heading}</h2>
    </div>

    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8">
      {categories.map((category, ci) => (
        <div class="skills-card card reveal" style={`transition-delay: ${ci * 0.1}s;`}>
          <h3 class="category-title">{category.title}</h3>

          <div class="skill-grid">
            {category.skills.map((skill) => (
              <div class="skill-item">
                <div class="icon-tile">
                  <img
                    src={withBase(
                      skill.icon.includes(':')
                        ? `/images/icons/${skill.icon.replace(':', '/')}.svg`
                        : skill.icon
                    )}
                    alt={skill.name}
                    class="skill-icon"
                    loading="lazy"
                    width="36"
                    height="36"
                  />
                </div>
                <span class="skill-name">{skill.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* ── Category cards ──────────────────────────────── */
  .skills-card {
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }
  .skills-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 42px rgba(2, 6, 23, 0.32);
    border-color: color-mix(in srgb, var(--accent), transparent 50%);
  }

  .category-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.25rem;
  }

  /* ── Skill grid ──────────────────────────────────── */
  .skill-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(68px, 1fr));
    gap: 1rem 0.6rem;
  }

  .skill-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .skill-item:hover {
    transform: translateY(-3px) scale(1.06);
  }

  /* ── Icon tile — neutral bg so all icons are visible ─ */
  .icon-tile {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 0.6rem;
    background: rgba(248, 250, 252, 0.92);
    transition: background 0.2s ease, box-shadow 0.2s ease;
  }
  .skill-item:hover .icon-tile {
    background: rgba(255, 255, 255, 1);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.18);
  }

  .skill-icon {
    width: 34px;
    height: 34px;
    object-fit: contain;
  }

  .skill-name {
    font-size: 0.65rem;
    font-weight: 500;
    color: #64748b;
    line-height: 1.2;
    transition: color 0.2s ease;
  }
  .skill-item:hover .skill-name {
    color: #94a3b8;
  }

  /* ── Light theme ─────────────────────────────────── */
  :global([data-theme='light']) .icon-tile {
    background: rgba(226, 232, 240, 0.8);
  }
  :global([data-theme='light']) .skill-item:hover .icon-tile {
    background: rgba(203, 213, 225, 0.95);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
  }
  :global([data-theme='light']) .skills-card:hover {
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.08);
  }
  :global([data-theme='light']) .skill-name { color: var(--text-muted); }
  :global([data-theme='light']) .skill-item:hover .skill-name { color: var(--accent); }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 480px) {
    .skill-grid { grid-template-columns: repeat(auto-fill, minmax(60px, 1fr)); }
  }
</style>

<script>
  document.querySelectorAll('#skills .reveal').forEach((el) => {
    const io = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) { el.classList.add('visible'); io.disconnect(); }
      },
      { threshold: 0.1 }
    );
    io.observe(el);
  });
</script>
